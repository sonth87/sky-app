{
  "name": "sky-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Nền tảng multi-app đa môi trường (Web + Electron, Online + Offline)",
  "packageManager": "pnpm@10.21.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "changeset": "changeset",
    "dev:app": "turbo run dev --filter=@sky-app/shell-electron",
    "dev:web": "turbo run dev --filter=@sky-app/shell-web",
    "app:mac": "turbo run dist:mac --filter=@sky-app/shell-electron",
    "app:win": "turbo run dist:win --filter=@sky-app/shell-electron",
    "app:all": "turbo run dist:all --filter=@sky-app/shell-electron",
    "app:renderer-bundle": "turbo run build:renderer-bundle --filter=@sky-app/shell-electron"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@vitest/coverage-v8": "3.2.7",
    "turbo": "^2.5.4",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.7",
      "react-dom": "^19.2.7"
    }
  }
}
