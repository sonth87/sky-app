# Copy sang .env (không commit — đã gitignored) và điền giá trị cần dùng.
# Nạp bởi electron/slide/env.ts's loadEnv(), gọi sớm nhất trong app.whenReady().
# Candidate path (theo thứ tự, không ghi đè lẫn nhau — override:false):
#   1. process.cwd()/.env                (dev, chạy từ apps/shell-electron)
#   2. app.getAppPath()/.env             (dev fallback)
#   3. process.resourcesPath/.env        (packaged — bundle vào resources/.env)
#   4. cạnh file exe/app                 (override tại máy chạy, không cần build lại)

# GĐ8 OTA Update (Loại 1a) — URL manifest.json cho renderer self-update.
# Không set = tắt hẳn cơ chế check update (app chỉ dùng dist/ đóng gói sẵn).
# RENDERER_MANIFEST_URL=https://example.com/sky-app/manifest.json

# Cấu hình API tích hợp mặc định (đọc ở electron/slide/socket-server.ts).
# DEFAULT_API_CONFIG=

# URL bundle dữ liệu mẫu ceremony (đọc ở electron/slide/data/sync.ts).
# BUNDLE_URL=http://localhost:4000/ceremonies/1/bundle

# Port cho VieNeu TTS server (đọc ở electron/slide/python-server.ts).
# VIENEU_PORT=

# PYTHONPATH cho tts-service khi chạy dev qua venv nguồn.
# PYTHONPATH=
