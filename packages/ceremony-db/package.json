{
  "name": "@sky-app/ceremony-db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist-cjs/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist-cjs/node.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && cp dist-cjs-package.json dist-cjs/package.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sky-app/slide-shared": "workspace:*",
    "better-sqlite3": "^12.11.1",
    "sql.js": "1.14.1"
  },
  "devDependencies": {
    "@sky-app/tsconfig": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.20",
    "@types/sql.js": "^1.4.11",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
