{
  "extends": "@sky-app/tsconfig/base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": "src",
    "resolveJsonModule": true,
    // DOM cần cho drivers/indexeddb-persist.ts (chạy trong trình duyệt qua SqlJsExecutor) —
    // các file Node-only khác (better-sqlite3-executor.ts) không đụng API nào xung đột với DOM.
    "lib": ["ES2022", "DOM"]
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules", "src/**/*.test.ts"]
}
